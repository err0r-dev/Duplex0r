# =============================================================================
# Duplex0r Environment Variables
# =============================================================================

# Database Configuration
# ----------------------
# SQLite (default - for development/personal use):
DATABASE_URL=sqlite+aiosqlite:////app/backend/api/data/app.db

# PostgreSQL (for production):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/duplex0r

# CORS Configuration
# ------------------
# JSON array of allowed origins, or ["*"] for all
ALLOW_ORIGINS=["*"]

# Frontend Static Files (Docker only)
# ------------------------------------
# Set to "true" to serve frontend from FastAPI (production Docker setup)
SERVE_FRONTEND=false
